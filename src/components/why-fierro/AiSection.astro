<section class="bg-gunmetal py-16 lg:py-24" data-testid="ai-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl" data-animate>
      <h2 class="text-3xl font-bold text-off-white sm:text-4xl">
        Your AI Tools, Your Data
      </h2>
      <p class="mt-6 text-lg text-off-white/70 leading-relaxed">
        Fierro connects directly to tools you already use — like ChatGPT — so
        you can ask questions about your project finances, get budget insights,
        and generate reports using your own data. You stay in control of what
        your AI tools can see and do.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="rounded-lg border border-off-white/10 bg-off-white/5 p-6" data-animate>
          <h3 class="text-lg font-semibold text-off-white">Ask Your AI Anything</h3>
          <p class="mt-2 text-off-white/70">
            "Am I over budget on electrical?" "What did I spend at Home Depot
            last month?" Get real answers from your real data.
          </p>
        </div>
        <div class="rounded-lg border border-off-white/10 bg-off-white/5 p-6" data-animate>
          <h3 class="text-lg font-semibold text-off-white">Instant Reports</h3>
          <p class="mt-2 text-off-white/70">
            Ask ChatGPT to summarize your project costs, flag budget overruns,
            or build a report for your partner, lender, or accountant.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

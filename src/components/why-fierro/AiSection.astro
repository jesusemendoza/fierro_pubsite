<section class="bg-gunmetal py-16 lg:py-24" data-testid="ai-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl" data-animate>
      <h2 class="text-3xl font-bold text-off-white sm:text-4xl">
        Smart Budget Insights
      </h2>
      <p class="mt-6 text-lg text-off-white/70 leading-relaxed">
        Fierro uses AI to surface what matters — like flagging a budget category
        that's trending over, or summarizing your project costs into a clean
        report. No setup required, no jargon. It just works in the background to
        keep you informed.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="rounded-lg border border-off-white/10 bg-off-white/5 p-6" data-animate>
          <h3 class="text-lg font-semibold text-off-white">Trend Alerts</h3>
          <p class="mt-2 text-off-white/70">
            Get notified when spending in any category is on pace to exceed your
            budget.
          </p>
        </div>
        <div class="rounded-lg border border-off-white/10 bg-off-white/5 p-6" data-animate>
          <h3 class="text-lg font-semibold text-off-white">Instant Reports</h3>
          <p class="mt-2 text-off-white/70">
            Generate a project cost summary in seconds. Share it with your
            partner, lender, or accountant.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

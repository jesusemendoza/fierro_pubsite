---
interface Props {
  problem: string;
  cause: string;
  solution: string;
  index: number;
}

const { problem, cause, solution, index } = Astro.props;
const isEven = index % 2 === 0;
---

<div
  class:list={[
    'relative space-y-4 border-l-4 pl-6 lg:pl-8',
    isEven ? 'border-molten-orange' : 'border-rebar-green',
  ]}
  data-animate
>
  <h2 class="text-2xl font-bold text-gunmetal lg:text-3xl">
    {problem}
  </h2>
  <p class="text-lg text-concrete-gray leading-relaxed">
    {cause}
  </p>
  <p class="text-lg font-medium text-gunmetal leading-relaxed">
    {solution}
  </p>
</div>

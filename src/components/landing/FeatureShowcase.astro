---
import FeatureRow from './FeatureRow.astro';
import { screenshotUrl } from '../../utils/screenshot';
---

<section id="features" class="bg-off-white py-16 lg:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="mb-16 text-center text-3xl font-bold text-gunmetal">
      Everything you need to stay on budget
    </h2>

    <div class="space-y-16 lg:space-y-24">
      <!-- Row 1: Budget Tracking -->
      <FeatureRow
        title="Budget Tracking"
        description="Set your renovation budget and watch every dollar against the plan. No more end-of-project surprises."
        bullets={[
          "Create a budget in minutes — just list your categories and targets",
          "See how much you've spent vs. what's left in real time",
          "Get alerts before you go over in any category"
        ]}
        imageUrl={screenshotUrl('desktop/homeowner-dashboard.webp')}
        alt="Real-time budget tracking with spent vs. remaining amounts"
      />

      <!-- Row 2: Expense Management -->
      <FeatureRow
        title="Expense Management"
        description="Every receipt, every invoice, every payment — in one place. Stop losing track of what you've paid."
        bullets={[
          "Snap receipts on your phone at the store or job site",
          "Attach contractor invoices to the right budget category",
          "Review and approve expenses before they pile up"
        ]}
        reverse={true}
        imageUrl={screenshotUrl('desktop/homeowner-expenses.webp')}
        alt="Expense timeline with status badges and vendor details"
      />

      <!-- Row 3: Team Management -->
      <FeatureRow
        title="Team Management"
        description="Share access with your contractor, designer, or spouse. Everyone sees what they need."
        bullets={[
          "Invite people with different permission levels",
          "Your contractor logs expenses, you approve them",
          "See who spent what, when, from anywhere"
        ]}
        imageUrl={screenshotUrl('desktop/homeowner-team.webp')}
        alt="Project team view showing owner, contractor, and trade roles"
      />

      <!-- Row 4: Vendor Management -->
      <FeatureRow
        title="Vendor Management"
        description="Keep every contractor, supplier, and service provider organized in one place."
        bullets={[
          "Build a directory of everyone working on your project",
          "Link invoices to specific vendors and budget categories",
          "Compare costs across projects to spot who's overcharging"
        ]}
        reverse={true}
        imageUrl={screenshotUrl('desktop/homeowner-expense-detail.webp')}
        alt="Expense detail with vendor, category, and approval information"
      />

      <!-- Row 5: Analytics & Reporting -->
      <FeatureRow
        title="Analytics &amp; Reporting"
        description="See the big picture before small problems become big ones."
        bullets={[
          "Visual dashboard showing your budget health at a glance",
          "Export reports for your partner, lender, or accountant",
          "Spot trends — is your electrical always running over?"
        ]}
        imageUrl={screenshotUrl('desktop/homeowner-audit.webp')}
        alt="Project audit log with expense activity timeline"
      />
    </div>
  </div>
</section>

---
const features = [
  { name: 'Projects', free: '1', home: '2', plus: '5', builder: 'Unlimited' },
  { name: 'Sub-projects per project', free: '6', home: '15', plus: '20', builder: 'Unlimited' },
  { name: 'Team members', free: '3', home: '5', plus: '10', builder: 'Unlimited' },
  { name: 'Expense tracking', free: 'Basic', home: 'Advanced', plus: 'Advanced', builder: 'Advanced' },
  { name: 'Receipt photo capture', free: '\u2014', home: 'Included', plus: 'Included', builder: 'Included' },
  { name: 'Budget analytics', free: 'Summary', home: 'Visual dashboard', plus: 'Detailed reports', builder: 'Custom dashboards' },
  { name: 'Budget alerts', free: '\u2014', home: 'Included', plus: 'Included', builder: 'Included' },
  { name: 'Vendor management', free: '\u2014', home: '\u2014', plus: 'Included', builder: 'Included' },
  { name: 'AI insights', free: 'Limited', home: 'Basic', plus: 'Fully configurable', builder: 'Fully configurable' },
  { name: 'API access', free: '\u2014', home: '\u2014', plus: '\u2014', builder: 'Included' },
  { name: 'Support', free: 'Community', home: 'Email', plus: 'Priority', builder: 'Dedicated manager' },
];
---

<div class="overflow-x-auto">
  <table class="w-full text-sm text-left">
    <thead>
      <tr class="border-b-2 border-gunmetal/10">
        <th class="px-4 py-3 font-semibold text-gunmetal text-base">Feature</th>
        <th class="px-4 py-3 font-semibold text-gunmetal text-base text-center">Free</th>
        <th class="px-4 py-3 font-semibold text-gunmetal text-base text-center">Home</th>
        <th class="px-4 py-3 font-semibold text-gunmetal text-base text-center">Plus</th>
        <th class="px-4 py-3 font-semibold text-gunmetal text-base text-center">Builder</th>
      </tr>
    </thead>
    <tbody>
      {features.map((feature, i) => (
        <tr class:list={[
          'border-b border-concrete-gray/10',
          i % 2 === 0 && 'bg-gunmetal/5',
        ]}>
          <td class="px-4 py-3 font-medium text-gunmetal">{feature.name}</td>
          <td class="px-4 py-3 text-concrete-gray text-center">{feature.free}</td>
          <td class="px-4 py-3 text-concrete-gray text-center">{feature.home}</td>
          <td class="px-4 py-3 text-concrete-gray text-center">{feature.plus}</td>
          <td class="px-4 py-3 text-concrete-gray text-center">{feature.builder}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

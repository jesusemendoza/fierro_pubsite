---

<pricing-toggle data-default="monthly">
  <div class="flex items-center justify-center gap-3">
    <span data-label="monthly" class="font-semibold text-off-white transition-colors">Monthly</span>
    <button
      type="button"
      role="switch"
      aria-checked="false"
      aria-label="Switch to annual billing"
      class="relative h-7 w-14 rounded-full bg-concrete-gray/30 transition-colors cursor-pointer"
    >
      <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-white transition-transform"></span>
    </button>
    <span data-label="annual" class="text-off-white/50 transition-colors">Annual</span>
  </div>
  <p data-savings class="mt-2 text-center text-sm font-medium text-rebar-green invisible">
    Save up to $118/year
  </p>
</pricing-toggle>

<script>
  class PricingToggle extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector<HTMLButtonElement>('button[role="switch"]');
      const thumb = btn?.querySelector<HTMLSpanElement>('span');
      const savingsEl = this.querySelector('[data-savings]');
      const monthlyLabel = this.querySelector('[data-label="monthly"]');
      const annualLabel = this.querySelector('[data-label="annual"]');

      let isAnnual = false;

      btn?.addEventListener('click', () => {
        isAnnual = !isAnnual;

        btn.setAttribute('aria-checked', String(isAnnual));
        btn.setAttribute(
          'aria-label',
          isAnnual ? 'Switch to monthly billing' : 'Switch to annual billing'
        );

        // Toggle thumb position and button color
        thumb?.classList.toggle('translate-x-7', isAnnual);
        btn.classList.toggle('bg-molten-orange', isAnnual);
        btn.classList.toggle('bg-concrete-gray/30', !isAnnual);

        // Toggle label styles
        monthlyLabel?.classList.toggle('text-off-white', !isAnnual);
        monthlyLabel?.classList.toggle('text-off-white/50', isAnnual);
        monthlyLabel?.classList.toggle('font-semibold', !isAnnual);
        annualLabel?.classList.toggle('text-off-white/50', !isAnnual);
        annualLabel?.classList.toggle('text-off-white', isAnnual);
        annualLabel?.classList.toggle('font-semibold', isAnnual);

        // Show/hide savings callout (invisible preserves layout)
        savingsEl?.classList.toggle('invisible', !isAnnual);

        // Update all price displays on the page
        document.querySelectorAll('[data-price-monthly]').forEach((el) => {
          const monthly = el.getAttribute('data-price-monthly');
          const annual = el.getAttribute('data-price-annual');
          if (monthly && annual) {
            el.textContent = isAnnual ? annual : monthly;
          }
        });

        // Update CTA billing query params
        document.querySelectorAll<HTMLAnchorElement>('[data-billing-link]').forEach((el) => {
          const href = el.getAttribute('href') || '';
          const updated = href.replace(
            /billing=(monthly|annual)/,
            `billing=${isAnnual ? 'annual' : 'monthly'}`
          );
          el.setAttribute('href', updated);
        });

        // Show/hide annual note elements
        document.querySelectorAll('[data-annual-note]').forEach((el) => {
          el.classList.toggle('hidden', !isAnnual);
        });
      });
    }
  }

  customElements.define('pricing-toggle', PricingToggle);
</script>

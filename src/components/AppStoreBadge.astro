---
import { APP_STORE_URL } from '../utils/appStore';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a
  href={APP_STORE_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Download Fierro on the App Store"
  class:list={['inline-block', className]}
>
  <!-- Official Apple "Download on the App Store" badge -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width="200" height="67" role="img" aria-hidden="true">
    <title>Download on the App Store</title>
    <rect width="120" height="40" rx="6" fill="#000" />
    <rect x="0.5" y="0.5" width="119" height="39" rx="5.5" stroke="#a6a6a6" stroke-width="0.4" fill="none" />
    <!-- Apple logo -->
    <g fill="#fff">
      <path d="M24.77 20.3a4.95 4.95 0 0 1 2.36-4.15 5.07 5.07 0 0 0-3.99-2.16c-1.68-.18-3.31 1.01-4.17 1.01-.87 0-2.19-.99-3.62-.96a5.33 5.33 0 0 0-4.49 2.73c-1.93 3.34-.49 8.27 1.36 10.97.93 1.33 2.01 2.82 3.44 2.76 1.39-.06 1.91-.89 3.59-.89 1.66 0 2.14.89 3.59.86 1.49-.02 2.43-1.33 3.33-2.67a11.03 11.03 0 0 0 1.52-3.09 4.77 4.77 0 0 1-2.92-4.41z" />
      <path d="M22.04 12.21a4.87 4.87 0 0 0 1.11-3.49 4.96 4.96 0 0 0-3.21 1.66 4.64 4.64 0 0 0-1.14 3.37 4.11 4.11 0 0 0 3.24-1.54z" />
    </g>
    <!-- "Download on the" text -->
    <g fill="#fff" style="font-family: 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;">
      <text x="36" y="15" font-size="5.5" letter-spacing="0.02em">Download on the</text>
      <text x="36" y="28" font-size="11.5" font-weight="600" letter-spacing="-0.01em">App Store</text>
    </g>
  </svg>
</a>

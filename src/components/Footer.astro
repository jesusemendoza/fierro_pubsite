---
const currentYear = new Date().getFullYear();
---

<footer aria-label="Site footer" class="border-t border-concrete-gray/20 bg-off-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <!-- Logo and copyright -->
      <div class="flex flex-col gap-3">
        <a href="/" class="text-lg font-bold text-gunmetal">
          Fierro
        </a>
        <p class="text-sm text-concrete-gray">
          &copy; {currentYear} Fierro. All rights reserved.
        </p>
      </div>

      <!-- Page links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3" aria-label="Footer navigation">
        <a
          href="/#features"
          class="text-sm text-concrete-gray transition-colors hover:text-molten-orange"
        >
          Features
        </a>
        <a
          href="/pricing"
          class="text-sm text-concrete-gray transition-colors hover:text-molten-orange"
        >
          Pricing
        </a>
        <a
          href="/why-fierro"
          class="text-sm text-concrete-gray transition-colors hover:text-molten-orange"
        >
          Why Fierro
        </a>
        <a
          href="/privacy"
          class="text-sm text-concrete-gray transition-colors hover:text-molten-orange"
        >
          Privacy
        </a>
        <a
          href="/terms"
          class="text-sm text-concrete-gray transition-colors hover:text-molten-orange"
        >
          Terms
        </a>
      </nav>

      <!-- Signup CTA -->
      <div class="flex flex-col items-start gap-2 md:items-end">
        <p class="text-sm font-medium text-gunmetal">Ready to take control?</p>
        <a
          href="https://app.getfierro.com/signup"
          class="text-sm font-semibold text-molten-orange transition-colors hover:text-molten-orange/80"
        >
          Start Free &rarr;
        </a>
      </div>
    </div>
  </div>
</footer>

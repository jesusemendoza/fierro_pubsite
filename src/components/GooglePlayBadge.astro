---
import { GOOGLE_PLAY_URL } from '../utils/appStore';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<a
  href={GOOGLE_PLAY_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Get Fierro on Google Play"
  class:list={['inline-block', className]}
>
  <!-- Official "Get it on Google Play" style badge -->
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" class="w-[150px] h-auto sm:w-[160px] lg:w-[150px]" role="img" aria-hidden="true">
    <title>Get it on Google Play</title>
    <rect width="120" height="40" rx="6" fill="#000" />
    <rect x="0.5" y="0.5" width="119" height="39" rx="5.5" stroke="#a6a6a6" stroke-width="0.4" fill="none" />
    <!-- Play triangle icon -->
    <g transform="translate(10, 7)">
      <defs>
        <linearGradient id="gp-blue" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#00c3ff" />
          <stop offset="100%" stop-color="#1a73e8" />
        </linearGradient>
        <linearGradient id="gp-green" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#00f076" />
          <stop offset="100%" stop-color="#00c853" />
        </linearGradient>
        <linearGradient id="gp-red" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#ff3a44" />
          <stop offset="100%" stop-color="#c31162" />
        </linearGradient>
        <linearGradient id="gp-yellow" x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#ffd500" />
          <stop offset="100%" stop-color="#ffbc00" />
        </linearGradient>
      </defs>
      <!-- Simplified Play Store icon -->
      <path d="M1 1.5 L1 24.5 L14 13Z" fill="url(#gp-blue)" />
      <path d="M1 1.5 L14 13 L17.5 9.5 L4.5 0Z" fill="url(#gp-green)" />
      <path d="M1 24.5 L14 13 L17.5 16.5 L4.5 26Z" fill="url(#gp-red)" />
      <path d="M17.5 9.5 L14 13 L17.5 16.5 L21 13Z" fill="url(#gp-yellow)" />
    </g>
    <!-- Text -->
    <g fill="#fff" style="font-family: 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif;">
      <text x="36" y="15.5" font-size="7" letter-spacing="0.03em">GET IT ON</text>
      <text x="36" y="28.5" font-size="13" font-weight="600" letter-spacing="-0.01em">Google Play</text>
    </g>
  </svg>
</a>

---
import logoSrc from '../assets/logo.svg';
---

<nav
  id="main-nav"
  aria-label="Main navigation"
  class="fixed top-0 left-0 z-50 w-full bg-transparent transition-colors duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0">
      <img
        src={logoSrc.src}
        alt="Fierro"
        class="h-8 w-auto brightness-0 invert"
      />
    </a>

    <!-- Desktop nav links -->
    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/#features"
        class="text-sm font-medium text-white transition-colors hover:text-molten-orange"
      >
        Features
      </a>
      <a
        href="/pricing"
        class="text-sm font-medium text-white transition-colors hover:text-molten-orange"
      >
        Pricing
      </a>
      <a
        href="/why-fierro"
        class="text-sm font-medium text-white transition-colors hover:text-molten-orange"
      >
        Why Fierro
      </a>
    </div>

    <!-- Desktop auth links -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href="https://app.getfierro.com/login"
        class="text-sm font-medium text-white transition-colors hover:text-molten-orange"
      >
        Login
      </a>
      <a
        href="https://app.getfierro.com/signup"
        class="rounded-md border border-molten-orange px-4 py-2 text-sm font-semibold text-molten-orange transition-colors hover:bg-molten-orange hover:text-white"
      >
        Start Free
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      type="button"
      class="flex min-h-[44px] min-w-[44px] items-center justify-center md:hidden"
      aria-label="Toggle menu"
    >
      <svg
        class="h-6 w-6 text-white"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const nav = document.getElementById('main-nav');
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuClose = document.getElementById('menu-close');

    // Scroll-based background transition
    const handleScroll = () => {
      if (window.scrollY > 50) {
        nav?.classList.add('bg-gunmetal');
        nav?.classList.remove('bg-transparent');
      } else {
        nav?.classList.remove('bg-gunmetal');
        nav?.classList.add('bg-transparent');
      }
    };
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Mobile menu toggle
    const openMenu = () => {
      mobileMenu?.classList.remove('hidden');
      document.body.classList.add('overflow-hidden');
    };
    const closeMenu = () => {
      mobileMenu?.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    };
    toggle?.addEventListener('click', openMenu);
    menuClose?.addEventListener('click', closeMenu);

    // Close mobile menu when a link is clicked
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  });
</script>

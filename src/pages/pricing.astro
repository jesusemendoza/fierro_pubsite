---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingToggle from '../components/pricing/PricingToggle.astro';
import TierCard from '../components/pricing/TierCard.astro';
import ComparisonTable from '../components/pricing/ComparisonTable.astro';
import PricingFaq from '../components/pricing/PricingFaq.astro';
import ClosingCta from '../components/landing/ClosingCta.astro';

const tiers = [
  {
    name: 'Free',
    price: { monthly: '$0', annual: '$0' },
    period: '/mo',
    description: 'For your first project',
    cta: { text: 'Start Free', href: 'https://app.getfierro.com/signup' },
    features: [
      '1 project',
      '6 sub-projects',
      '2 team members',
      'Receipt capture (100 MB)',
      'Basic expense tracking',
      'ChatGPT integration (read-only)',
    ],
    highlighted: false,
    builder: false,
  },
  {
    name: 'Home',
    price: { monthly: '$20', annual: '$16' },
    period: '/mo',
    description: 'For homeowners managing a renovation or remodel',
    cta: { text: 'Start Home', href: 'https://app.getfierro.com/signup?plan=home&billing=monthly' },
    features: [
      '2 projects',
      '15 sub-projects per project',
      '5 team members',
      '5 contractors (free)',
      'Receipt capture (5 GB)',
      'Role-based access',
      'Advanced expense tracking',
      'CSV & PDF export',
      'ChatGPT integration (read & write)',
      'Budget alerts',
      'Email support',
    ],
    highlighted: true,
    builder: false,
  },
  {
    name: 'Plus',
    price: { monthly: '$49', annual: '$39' },
    period: '/mo',
    description: 'For investors & flippers managing multiple properties',
    cta: { text: 'Start Plus', href: 'https://app.getfierro.com/signup?plan=plus&billing=monthly' },
    features: [
      '8 projects',
      '20 sub-projects per project',
      '10 team members',
      'Unlimited contractors (free)',
      'Receipt capture (25 GB)',
      'Role-based access',
      'Advanced analytics',
      'CSV & PDF export',
      'Vendor management',
      'ChatGPT integration (configurable per project)',
      'Audit logs',
      'Priority support',
    ],
    highlighted: false,
    builder: false,
  },
  {
    name: 'Builder',
    price: { monthly: 'Custom', annual: 'Custom' },
    period: '',
    description: 'For enterprises that need everything',
    cta: { text: 'Contact Sales', href: '#contact-sales' },
    features: [
      'Unlimited projects',
      'Unlimited sub-projects',
      'Unlimited team members',
      'Unlimited contractors (free)',
      'Unlimited receipt storage',
      'Role-based access',
      'Custom integrations',
      'ChatGPT integration (configurable per project)',
      'Audit logs',
      'Dedicated account manager',
      'API access',
    ],
    highlighted: false,
    builder: true,
  },
];
---

<BaseLayout
  title="Pricing"
  description="Free for your first project. Home tier at $20/mo for renovations. Plus at $49/mo for investors and flippers. No sales calls, no hidden fees."
  ogImage="/og/pricing.png"
>
  <noscript>
    <style>
      [data-animate] { opacity: 1 !important; transform: none !important; }
    </style>
  </noscript>

  <!-- Dark hero/header section -->
  <section class="bg-gunmetal pt-28 pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl font-bold text-off-white sm:text-4xl lg:text-5xl" data-animate>
        Plans That Fit Your Project
      </h1>
      <p class="mt-4 text-lg text-off-white/70 max-w-2xl mx-auto" data-animate>
        Tracking a kitchen remodel? Free. Managing a portfolio of flips? $49/mo for 8 projects. No sales calls, no surprises.
      </p>
      <div class="mt-8" data-animate>
        <PricingToggle />
      </div>
    </div>
  </section>

  <!-- Tier cards section -->
  <section class="bg-off-white py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-animate-stagger>
        {tiers.map((tier) => (
          <TierCard {...tier} />
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table section -->
  <section class="bg-white py-16 lg:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gunmetal text-center sm:text-3xl mb-12" data-animate>
        Compare Plans
      </h2>
      <div data-animate>
        <ComparisonTable />
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="bg-off-white py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gunmetal text-center sm:text-3xl mb-12" data-animate>
        Common Questions
      </h2>
      <div data-animate>
        <PricingFaq />
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <ClosingCta />
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const targets = document.querySelectorAll('[data-animate]');
    if (!targets.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -50px 0px' }
    );

    targets.forEach((el) => observer.observe(el));
  });
</script>

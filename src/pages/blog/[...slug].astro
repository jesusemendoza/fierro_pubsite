---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogType="article"
>
  <!-- Header -->
  <section class="bg-gunmetal pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-1 text-sm text-concrete-gray transition-colors hover:text-molten-orange"
      >
        &larr; Back to Blog
      </a>

      <div class="mt-8" data-animate>
        <span class="text-xs font-semibold uppercase tracking-wider text-molten-orange">
          {post.data.category}
        </span>

        <h1 class="mt-3 text-3xl font-bold tracking-tight text-off-white sm:text-4xl lg:text-5xl">
          {post.data.title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-concrete-gray">
          <span>{post.data.author}</span>
          <span aria-hidden="true">&middot;</span>
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">&middot;</span>
              <span>
                Updated {formatDate(post.data.updatedDate)}
              </span>
            </>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content -->
  <section class="bg-off-white py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <article class="blog-content" data-animate>
        <Content />
      </article>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gunmetal py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8" data-animate>
      <h2 class="text-3xl font-bold text-off-white sm:text-4xl">
        Ready to take control of your renovation budget?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-concrete-gray">
        Track every dollar, share costs with your team, and never lose sight of your budget again.
      </p>
      <a
        href="https://app.getfierro.com/signup"
        class="mt-8 inline-block rounded-md bg-molten-orange px-6 py-3 text-white font-semibold transition-colors hover:bg-molten-orange/90"
      >
        Start Free
      </a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .blog-content h2 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 700;
    color: var(--color-gunmetal);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-content h3 {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 600;
    color: var(--color-gunmetal);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-content p {
    color: color-mix(in srgb, var(--color-gunmetal) 80%, transparent);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .blog-content ul,
  .blog-content ol {
    color: color-mix(in srgb, var(--color-gunmetal) 80%, transparent);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content li {
    margin-bottom: 0.5rem;
  }

  .blog-content strong {
    color: var(--color-gunmetal);
    font-weight: 600;
  }

  .blog-content a {
    color: var(--color-molten-orange);
    text-decoration: none;
    transition: text-decoration 0.15s;
  }

  .blog-content a:hover {
    text-decoration: underline;
  }

  .blog-content blockquote {
    border-left: 4px solid var(--color-molten-orange);
    padding-left: 1rem;
    font-style: italic;
    color: color-mix(in srgb, var(--color-gunmetal) 80%, transparent);
    margin-bottom: 1.5rem;
  }

  .blog-content blockquote p {
    margin-bottom: 0;
  }

  .blog-content img {
    border-radius: 0.5rem;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
  }

  .blog-content hr {
    border-color: color-mix(in srgb, var(--color-concrete-gray) 20%, transparent);
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .blog-content code {
    background-color: color-mix(in srgb, var(--color-concrete-gray) 15%, transparent);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
  }

  .blog-content pre {
    background-color: var(--color-gunmetal);
    color: var(--color-off-white);
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .blog-content pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 0.875rem;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog"
  description="Insights for homeowners, flippers, and investors managing renovation budgets."
  ogType="website"
>
  <!-- Hero -->
  <section class="bg-gunmetal pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center" data-animate>
        <h1 class="text-4xl font-bold tracking-tight text-off-white sm:text-5xl">
          The Fierro Blog
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-concrete-gray">
          Insights for homeowners, flippers, and investors managing renovation budgets.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="bg-off-white py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {posts.length === 0 && (
        <p class="text-center text-concrete-gray text-lg">
          No posts yet. Check back soon!
        </p>
      )}

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex flex-col rounded-lg border border-concrete-gray/20 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
            data-animate
          >
            <span class="text-xs font-semibold uppercase tracking-wider text-molten-orange">
              {post.data.category}
            </span>

            <h2 class="mt-3 text-xl font-bold text-gunmetal group-hover:text-molten-orange transition-colors">
              {post.data.title}
            </h2>

            <p class="mt-2 flex-1 text-sm leading-relaxed text-concrete-gray">
              {post.data.description}
            </p>

            <div class="mt-6 flex items-center justify-between">
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs text-concrete-gray"
              >
                {formatDate(post.data.date)}
              </time>

              <span class="text-sm font-medium text-molten-orange transition-colors group-hover:text-molten-orange/80">
                Read more &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

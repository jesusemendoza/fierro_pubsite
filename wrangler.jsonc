{
  "name": "fierro-pubsite",
  "compatibility_date": "2026-03-09",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "getfierro.com/*", "zone_name": "getfierro.com" },
    { "pattern": "www.getfierro.com/*", "zone_name": "getfierro.com" }
  ]
}
